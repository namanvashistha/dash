# Home Assistant runtime state — secrets, database, logs, cache.
# We only version the config files we author; HA generates the rest at runtime.
homeassistant/config/*
!homeassistant/config/configuration.yaml
!homeassistant/config/automations.yaml
!homeassistant/config/scripts.yaml
!homeassistant/config/scenes.yaml

# never commit secrets
homeassistant/config/secrets.yaml

# compose reads this for ${GLANCE_GITHUB_TOKEN} etc — keep secrets out of git
.env
