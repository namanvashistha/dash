# Copy to .env on the server (it's gitignored). docker-compose auto-reads it.

# Optional: GitHub token (classic, public_repo scope) — lifts the 60/hr anon
# limit for the Glance repository/releases widgets. Blank = anonymous.
GLANCE_GITHUB_TOKEN=

# Optional: Home Assistant long-lived access token — enables the "Home
# Assistant" bridge widget on the Infra page. Create one in HA:
# profile (bottom-left) → Security → Long-lived access tokens → Create.
# Blank = the HA widget shows an auth error (everything else still works).
HA_TOKEN=

# Docmost (self-hosted wiki at docs.namanvashistha.com). BOTH are required for
# the docmost/docmost-db containers to boot — leaving them blank breaks startup.
# Generate the secret with: openssl rand -hex 32
DOCMOST_APP_SECRET=
# Postgres password for the docmost DB. Pick any strong string (used by both
# docmost and docmost-db). Changing it after first boot means recreating the DB.
DOCMOST_DB_PASSWORD=
